# Copy this file to `.env.local` and fill in the values.
#   cp .env.local.example .env.local
# NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# The public site works on seed data until Supabase is configured.

# ── Supabase (required for the admin panel + live content) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional — storage bucket for uploaded media (defaults to "media").
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media
# Note: the app authenticates writes with the signed-in admin's session + the
# anon key under RLS. No SUPABASE_SERVICE_ROLE_KEY is used by the app itself.

# ── Contact form: email delivery (Resend) ─────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
CONTACT_TO_EMAIL=you@example.com
# Optional — verified sender (defaults to Resend's onboarding address).
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# ── Contact form: CAPTCHA (Cloudflare Turnstile) ──────────────────────────────
# If the public site key is set in production, the secret MUST also be set or
# submissions are rejected (fail closed). Leave both unset to disable CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the canonical/OG/sitemap base URL (e.g. for preview deploys).
# NEXT_PUBLIC_SITE_URL=https://www.kalanalk.com
# Google Search Console verification token.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-token
