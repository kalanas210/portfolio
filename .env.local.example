# ─────────────────────────────────────────────────────────────
# Supabase — copy this file to `.env.local` and fill in the values
# from your Supabase project: Settings → API
# ─────────────────────────────────────────────────────────────

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL — service-role key (server-only, NEVER exposed to the browser).
# Only needed if you run server-side maintenance scripts. The admin panel
# works without it, using the logged-in admin's session + RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket used for uploaded media (images, videos, CV).
# Must match the bucket created by the migration. Default: "media".
NEXT_PUBLIC_SUPABASE_MEDIA_BUCKET=media

# ─────────────────────────────────────────────────────────────
# Contact form — email delivery (Resend) + spam protection (Turnstile)
# ─────────────────────────────────────────────────────────────

# Resend API key — https://resend.com → API Keys. Required to send mail.
RESEND_API_KEY=

# Where contact-form messages are delivered (your inbox).
CONTACT_TO_EMAIL=

# "From" address. Until you verify kalanalk.com in Resend, leave this unset to
# use Resend's shared sender. After verifying, set e.g.: "Kalana <contact@kalanalk.com>"
CONTACT_FROM_EMAIL=

# Cloudflare Turnstile keys — https://dash.cloudflare.com → Turnstile → Add widget.
# The site key is public (sent to the browser); the secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
